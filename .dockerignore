# Keep the build context small and reproducible.
__pycache__/
*.py[cod]
.venv/
venv/
env/
ENV/

.git/
.gitignore
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Secrets and local state never belong in the image.
.env
.env.local
*.env

