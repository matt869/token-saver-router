.cache/
*.sqlite
*.sqlite3
*.db
*.faiss
*.index
models_cache/
hf_cache/

# Docs / dev-only files not needed at runtime.
tests/
README.md
LICENSE
*.md
.dockerignore
Dockerfile

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
