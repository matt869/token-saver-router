# Copy to .env and fill in. Every value has a safe default in app/config.py,
# so the service runs out of the box; override only what you need.

# --- Remote (scored) model: Fireworks AI ---
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
REMOTE_MODEL=accounts/fireworks/models/gemma-2-9b-it
# Optional cheaper Fireworks model for "easy" tasks (delivers savings with no
# GPU). Empty = disabled; easy tasks then use the local model.
CHEAP_REMOTE_MODEL=
# Fallback $/1M tokens for any model not in app/pricing.py's table.
REMOTE_PRICE_PER_1M_USD=0.20

# --- Local (free / zero-scored) model ---
# Qwen 7B in bf16 needs ~15-16 GB VRAM; fall back to Qwen/Qwen2.5-3B-Instruct
# (or a 1.5B/2B model) if VRAM is tight.
LOCAL_MODEL=Qwen/Qwen2.5-7B-Instruct
LOCAL_DEVICE=cuda          # ROCm exposes AMD GPUs as "cuda" in PyTorch

# Deployment environment. "production" auto-enables 4-bit quantization; anything
# else (unset/development) keeps the dev-safe bf16/fp32 path. Aliases: APP_ENV, ENVIRONMENT.
ENV=development
# 4-bit NF4 via bitsandbytes (~5-6 GB vs ~15-16 GB bf16). Leave UNSET to use the
# ENV-based default (on in production, off in dev); set true/false to force it.
# Only applied on a GPU device, and only if bitsandbytes imports cleanly.
# LOAD_IN_4BIT=

# --- Routing behaviour ---
CLASSIFIER=llm             # "llm" = judge via local model (free); "heuristic" = regex/length
CONFIDENCE_THRESHOLD=0.6
COMPLEXITY_LENGTH_CUTOFF=24

# --- Generation limits ---
MAX_NEW_TOKENS=256
REMOTE_TIMEOUT=60
REMOTE_RETRIES=1           # extra attempts on transient 429/5xx/network errors
WARMUP_ENABLED=true        # preload local model + cache encoder at server boot
REMOTE_STUB=false          # keyless demo: swap the scored remote for a proportional stub

# --- Token-saving layers (all in front of the scored remote path) ---
PREFLIGHT_ENABLED=true     # strip whitespace/politeness/filler before remote
CACHE_ENABLED=true         # serve (near-)duplicate queries for zero remote tokens
CACHE_BACKEND=semantic     # "semantic" (MiniLM + faiss) or "exact" (hash only)
CACHE_MAX_ENTRIES=512      # LRU cap on the query cache
CACHE_SIMILARITY_THRESHOLD=0.95  # cosine cutoff for a semantic hit (conservative;
                                 # looser trades accuracy for token savings)
CACHE_PERSIST_PATH=        # sqlite file to persist the cache across restarts ("" = memory only)

# --- Embedding backend (shared by the semantic cache and --validate) ---
EMBED_BACKEND=local        # "local" (MiniLM via sentence-transformers) or "remote" (Fireworks API)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2   # local backend model
EMBED_REMOTE_MODEL=nomic-ai/nomic-embed-text-v1.5    # Fireworks embeddings model for the remote fallback
IDS_ENABLED=true           # regex inspection for heavy-compute signatures
IDS_THRESHOLD=0.5          # severity (0..1) at which IDS forces the remote route
FAILOVER_ENABLED=true      # on remote failure, serve from the local model
